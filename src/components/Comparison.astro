---
---

<section id="comparacion" class="py-20 relative overflow-hidden">
  <!-- Animated background -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50 dark:from-slate-900 dark:via-slate-800 dark:to-indigo-950/30"></div>
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-full">
      <div class="absolute top-1/4 -left-20 w-72 h-72 bg-blue-300/20 dark:bg-blue-600/10 rounded-full blur-2xl animate-pulse"></div>
      <div class="absolute bottom-1/4 -right-20 w-72 h-72 bg-indigo-300/20 dark:bg-indigo-600/10 rounded-full blur-2xl animate-pulse" style="animation-delay: 1.5s;"></div>
      <div class="absolute top-1/2 left-1/4 w-64 h-64 bg-purple-300/15 dark:bg-purple-600/10 rounded-full blur-2xl animate-pulse" style="animation-delay: 0.5s;"></div>
      <div class="absolute bottom-1/2 right-1/4 w-48 h-48 bg-blue-300/15 dark:bg-blue-600/10 rounded-full blur-2xl animate-pulse" style="animation-delay: 2s;"></div>
    </div>
  </div>

  <div class="relative max-w-4xl mx-auto px-3 sm:px-4 lg:px-6">
    <!-- Headline -->
    <div class="text-center mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-2">
        La matemática no miente
      </h2>
      <p class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-4">
        Eficiencia vs. Burocracia
      </p>
      <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Compara el costo bruto real de un solo sueldo mínimo en Chile con nuestro sistema operativo de ventas.
      </p>
    </div>

    <!-- Glassmorphism Table -->
    <div class="overflow-x-auto rounded-3xl">
      <div class="inline-block min-w-full rounded-3xl overflow-hidden shadow-2xl backdrop-blur-xl bg-white/70 dark:bg-slate-800/70 border border-white/40 dark:border-slate-700/40">
        <!-- Header Row -->
        <div class="grid grid-cols-2 bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950">
          <div class="px-6 py-5 text-left">
            <span class="text-xs font-semibold text-blue-400 uppercase tracking-wider">Gasto Real</span>
            <p class="text-lg font-bold text-white mt-1">1 Empleado</p>
          </div>
          <div class="px-6 py-5 text-right border-l border-slate-600/50 dark:border-slate-700/50">
            <span class="text-xs font-semibold text-blue-400 uppercase tracking-wider">Tu Inversión</span>
            <p class="text-lg font-bold text-white mt-1">Cobalt</p>
          </div>
        </div>

        <!-- Data Rows -->
        <div class="divide-y divide-slate-200/50 dark:divide-slate-700/50">
          <!-- Row 1 -->
          <div class="grid grid-cols-2 bg-white/50 dark:bg-slate-800/50">
            <div class="px-6 py-4">
              <span class="text-xs text-slate-400 uppercase">Sueldo Base</span>
              <p class="text-base font-bold text-slate-800 dark:text-slate-200 mt-0.5">539.000 CLP</p>
            </div>
            <div class="px-6 py-4 text-right bg-blue-100/50 dark:bg-blue-900/30 border-l border-blue-200/50 dark:border-blue-800/50">
              <span class="text-xs text-slate-400 uppercase">Suscripción</span>
              <p class="text-base font-bold text-blue-600 dark:text-blue-400 mt-0.5">8 UF (~300k)</p>
            </div>
          </div>

          <!-- Row 2 -->
          <div class="grid grid-cols-2 bg-slate-50/50 dark:bg-slate-800/30">
            <div class="px-6 py-4">
              <span class="text-xs text-slate-400 uppercase">Gratificación 25%</span>
              <p class="text-base font-bold text-slate-800 dark:text-slate-200 mt-0.5">134.750 CLP</p>
            </div>
            <div class="px-6 py-4 text-right bg-blue-100/50 dark:bg-blue-900/30 border-l border-blue-200/50 dark:border-blue-800/50">
              <span class="text-xs text-slate-400 uppercase">Gratificaciones</span>
              <p class="text-base font-bold text-blue-600 dark:text-blue-400 mt-0.5">0 CLP</p>
            </div>
          </div>

          <!-- Row 3 -->
          <div class="grid grid-cols-2 bg-white/50 dark:bg-slate-800/50">
            <div class="px-6 py-4">
              <span class="text-xs text-slate-400 uppercase">Seguros SIS/Cesantía</span>
              <p class="text-base font-bold text-slate-800 dark:text-slate-200 mt-0.5">Incluido</p>
            </div>
            <div class="px-6 py-4 text-right bg-blue-100/50 dark:bg-blue-900/30 border-l border-blue-200/50 dark:border-blue-800/50">
              <span class="text-xs text-slate-400 uppercase">Seguros</span>
              <p class="text-base font-bold text-blue-600 dark:text-blue-400 mt-0.5">0 CLP</p>
            </div>
          </div>

          <!-- Row 4 -->
          <div class="grid grid-cols-2 bg-slate-50/50 dark:bg-slate-800/30">
            <div class="px-6 py-4">
              <span class="text-xs text-slate-400 uppercase">Mutual/Leyes Sociales</span>
              <p class="text-base font-bold text-slate-800 dark:text-slate-200 mt-0.5">Por definir</p>
            </div>
            <div class="px-6 py-4 text-right bg-blue-100/50 dark:bg-blue-900/30 border-l border-blue-200/50 dark:border-blue-800/50">
              <span class="text-xs text-slate-400 uppercase">Días Libres</span>
              <p class="text-base font-bold text-blue-600 dark:text-blue-400 mt-0.5">0</p>
            </div>
          </div>

          <!-- Row 5 -->
          <div class="grid grid-cols-2 bg-white/50 dark:bg-slate-800/50">
            <div class="px-6 py-4">
              <span class="text-xs text-slate-400 uppercase">Vacaciones</span>
              <p class="text-base font-bold text-slate-800 dark:text-slate-200 mt-0.5">15 días/año</p>
            </div>
            <div class="px-6 py-4 text-right bg-blue-100/50 dark:bg-blue-900/30 border-l border-blue-200/50 dark:border-blue-800/50">
              <span class="text-xs text-slate-400 uppercase">Cancelación</span>
              <p class="text-base font-bold text-blue-600 dark:text-blue-400 mt-0.5">Con un Click</p>
            </div>
          </div>

          <!-- Total Row -->
          <div class="grid grid-cols-2">
            <div class="px-6 py-5 bg-gradient-to-r from-red-100/70 to-red-50/50 dark:from-red-900/50 dark:to-red-950/30">
              <span class="text-sm font-bold text-red-800 dark:text-red-300">Costo Empresa</span>
              <p class="text-2xl font-extrabold text-red-600 dark:text-red-400 mt-1">>820k CLP/mes</p>
            </div>
            <div class="px-6 py-5 bg-gradient-to-r from-blue-100/70 to-blue-50/50 dark:from-blue-900/50 dark:to-blue-950/30 text-right border-l border-blue-200/50 dark:border-blue-800/50">
              <span class="text-sm font-bold text-blue-800 dark:text-blue-300">Costo Fijo</span>
              <p class="text-2xl font-extrabold text-blue-600 dark:text-blue-400 mt-1">~300k CLP/mes</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Savings highlight -->
    <div class="mt-8 text-center">
      <p class="text-slate-600 dark:text-slate-400 text-sm">
        <span class="text-blue-600 dark:text-blue-400 font-bold">Ahorro:</span> 
        <span class="text-lg font-bold text-slate-900 dark:text-white">~520.000 CLP/mes</span>
        <span class="text-slate-500 dark:text-slate-500"> (63%)</span>
      </p>
    </div>
  </div>
</section>
