---
---

<section id="precios" class="py-20 bg-gradient-to-b from-white via-slate-50 to-white dark:from-slate-900 dark:via-slate-800 dark:to-slate-900 relative overflow-hidden">
  <!-- Background decorativo -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-50/30 to-transparent dark:via-blue-950/20"></div>
  <div class="absolute top-0 right-1/4 w-96 h-96 bg-blue-200/10 dark:bg-blue-900/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-1/4 w-96 h-96 bg-indigo-200/10 dark:bg-indigo-900/20 rounded-full blur-3xl"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Headline -->
    <div class="text-center mb-12">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-blue-100/80 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 text-xs font-bold uppercase tracking-widest mb-6">
        Pricing
      </span>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-slate-900 dark:text-white leading-tight">
        Simplifica tu operación
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 mt-3">
        Facturación profesional en UF
      </p>
    </div>

    <!-- Pricing Card principal -->
    <div class="relative">
      <!-- Badge -->
      <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10">
        <span class="inline-flex items-center gap-1.5 px-5 py-2 rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-sm font-bold shadow-xl shadow-blue-600/30">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5 2a2 2 0 00-2 2v14l3.5-2 3.5 2 3.5-2 3.5 2V4a2 2 0 00-2-2H5zm2.5 3a1.5 1.5 0 100 3 1.5 1.5 0 000-3zm6.207.293a1 1 0 00-1.414 0l-6 6a1 1 0 101.414 1.414l6-6a1 1 0 000-1.414zM12.5 10a1.5 1.5 0 100 3 1.5 1.5 0 000-3z" clip-rule="evenodd" />
          </svg>
          Mejor valor
        </span>
      </div>

      <div class="bg-white/80 dark:bg-slate-800/80 backdrop-blur-xl rounded-3xl shadow-2xl shadow-slate-200/50 dark:shadow-slate-900/50 border border-white/50 dark:border-slate-700/50 overflow-hidden">
        <!-- Card Header -->
        <div class="bg-gradient-to-r from-blue-600 via-blue-700 to-indigo-700 px-8 py-10 text-center">
          <h3 class="text-2xl font-bold text-white">Plan Operativo Único</h3>
          <p class="text-blue-100 mt-2">Todo lo que necesitas para automatizar tus ventas</p>
        </div>

        <!-- Card Body -->
        <div class="px-8 py-8">
          <!-- Pricing Items -->
          <div class="space-y-0">
            <!-- Setup -->
            <div class="flex justify-between items-center pb-5 border-b border-slate-100 dark:border-slate-700">
              <div>
                <p class="text-slate-700 dark:text-slate-200 font-bold">Setup/Implementación</p>
                <p class="text-slate-400 text-sm">Pago único</p>
              </div>
              <p class="text-3xl font-extrabold text-slate-900 dark:text-white">18.5 UF</p>
            </div>

            <!-- monthly -->
            <div class="flex justify-between items-center pt-5 pb-5">
              <div>
                <p class="text-slate-700 dark:text-slate-200 font-bold">Mensualidad</p>
                <p class="text-slate-400 text-sm">Facturación mensual</p>
              </div>
              <div class="text-right">
                <p class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400">8 UF</p>
                <p class="text-slate-500 dark:text-slate-400 text-sm">~$300.000 CLP/mes</p>
              </div>
            </div>
          </div>

          <!-- Includes -->
          <div class="bg-slate-50/80 dark:bg-slate-900/50 backdrop-blur-sm rounded-2xl p-5 mt-2">
            <p class="text-slate-700 dark:text-slate-200 font-bold mb-4">Incluye:</p>
            <ul class="space-y-3">
              <li class="flex items-center gap-3">
                <div class="w-5 h-5 bg-green-100 dark:bg-green-900/50 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-slate-600 dark:text-slate-300">Bot con RAG (Knowledge Base)</span>
              </li>
              <li class="flex items-center gap-3">
                <div class="w-5 h-5 bg-green-100 dark:bg-green-900/50 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-slate-600 dark:text-slate-300">Seguimiento automático 48h</span>
              </li>
              <li class="flex items-center gap-3">
                <div class="w-5 h-5 bg-green-100 dark:bg-green-900/50 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-slate-600 dark:text-slate-300">Entrenamiento con PDFs</span>
              </li>
              <li class="flex items-center gap-3">
                <div class="w-5 h-5 bg-green-100 dark:bg-green-900/50 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-slate-600 dark:text-slate-300">Soporte técnico B2B</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- CTA -->
        <div class="px-8 pb-8">
          <a
            href="https://wa.me/56927945837?text=Hola,%20me%20gustaria%20agendar%20una%20reunión%20para%20mi%20empresa"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full py-4 px-6 text-center text-lg font-bold text-white bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 focus:outline-none focus:ring-4 focus:ring-blue-600/25 rounded-2xl shadow-xl shadow-blue-600/20 hover:shadow-2xl hover:shadow-blue-600/25 transition-all duration-300 hover:-translate-y-1"
          >
            Agenda tu Implementación (UF)
          </a>
          <p class="text-center text-slate-400 dark:text-slate-500 text-sm mt-4">
            Sin compromiso. Respondemos rápido.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
