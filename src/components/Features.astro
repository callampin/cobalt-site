---
---

<section id="solucion" class="py-20 bg-gradient-to-b from-slate-50 via-white to-slate-50 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900 relative">
  <!-- Decorative -->
  <div class="absolute top-1/3 left-0 w-72 h-72 bg-blue-200/10 dark:bg-blue-900/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/3 right-0 w-72 h-72 bg-indigo-200/10 dark:bg-indigo-900/20 rounded-full blur-3xl"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Headline -->
    <div class="text-center mb-16">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-blue-100/80 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 text-xs font-bold uppercase tracking-widest mb-6">
        Tecnología avanzada
      </span>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-slate-900 dark:text-white leading-tight">
        Inteligencia Artificial que entiende<span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400"> tu negocio</span>
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 mt-4 max-w-2xl mx-auto">
        No solo un script. Una solución completa de automatización.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Feature 1 -->
      <div class="group relative bg-white/80 dark:bg-slate-800/80 backdrop-blur-sm rounded-3xl p-8 shadow-xl shadow-slate-200/50 dark:shadow-slate-900/50 border border-white/50 dark:border-slate-700/50 hover:shadow-2xl hover:shadow-slate-300/50 dark:hover:shadow-slate-700/50 hover:-translate-y-2 transition-all duration-300">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-indigo-500/5 dark:from-blue-500/10 dark:to-indigo-500/10 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <div class="relative">
          <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-blue-600/25 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">RAG Integrado</h3>
          <p class="text-slate-600 dark:text-slate-300 leading-relaxed">
            Lo entrenamos con los PDFs de tu empresa. Responde con precisión quirúrgica sobre tus servicios, sin inventar información.
          </p>
        </div>
      </div>

      <!-- Feature 2 -->
      <div class="group relative bg-white/80 dark:bg-slate-800/80 backdrop-blur-sm rounded-3xl p-8 shadow-xl shadow-slate-200/50 dark:shadow-slate-900/50 border border-white/50 dark:border-slate-700/50 hover:shadow-2xl hover:shadow-slate-300/50 dark:hover:shadow-slate-700/50 hover:-translate-y-2 transition-all duration-300">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-indigo-500/5 dark:from-blue-500/10 dark:to-indigo-500/10 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <div class="relative">
          <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-blue-600/25 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">Seguimiento Automático</h3>
          <p class="text-slate-600 dark:text-slate-300 leading-relaxed">
            Si el lead no responde, el bot lo contacta automáticamente a las 48 horas con un mensaje persuasivo para reactivar la venta.
          </p>
        </div>
      </div>

      <!-- Feature 3 -->
      <div class="group relative bg-white/80 dark:bg-slate-800/80 backdrop-blur-sm rounded-3xl p-8 shadow-xl shadow-slate-200/50 dark:shadow-slate-900/50 border border-white/50 dark:border-slate-700/50 hover:shadow-2xl hover:shadow-slate-300/50 dark:hover:shadow-slate-700/50 hover:-translate-y-2 transition-all duration-300">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-indigo-500/5 dark:from-blue-500/10 dark:to-indigo-500/10 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <div class="relative">
          <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-blue-600/25 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">Filtrado Cualificado</h3>
          <p class="text-slate-600 dark:text-slate-300 leading-relaxed">
            Identifica si el prospecto es un cliente real o un curioso, ahorrándole tiempo a tu equipo humano.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
