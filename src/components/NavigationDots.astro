---
---

<nav class="fixed right-6 top-1/2 -translate-y-1/2 z-40 hidden lg:flex flex-col items-center gap-4">
  <button 
    class="nav-dot w-3 h-3 rounded-full bg-slate-400 dark:bg-slate-600 hover:bg-blue-500 hover:cursor-pointer transition-all duration-200"
    data-section="0"
    data-target="hero"
    aria-label="Ir a inicio"
  ></button>
  <button 
    class="nav-dot w-3 h-3 rounded-full bg-slate-400 dark:bg-slate-600 hover:bg-blue-500 hover:cursor-pointer transition-all duration-200"
    data-section="1"
    data-target="problema"
    aria-label="Ir a problema"
  ></button>
  <button 
    class="nav-dot w-3 h-3 rounded-full bg-slate-400 dark:bg-slate-600 hover:bg-blue-500 hover:cursor-pointer transition-all duration-200"
    data-section="2"
    data-target="comparacion"
    aria-label="Ir a costos"
  ></button>
  <button 
    class="nav-dot w-3 h-3 rounded-full bg-slate-400 dark:bg-slate-600 hover:bg-blue-500 hover:cursor-pointer transition-all duration-200"
    data-section="3"
    data-target="solucion"
    aria-label="Ir a solución"
  ></button>
  <button 
    class="nav-dot w-3 h-3 rounded-full bg-slate-400 dark:bg-slate-600 hover:bg-blue-500 hover:cursor-pointer transition-all duration-200"
    data-section="4"
    data-target="precios"
    aria-label="Ir a precios"
  ></button>
  <button 
    class="nav-dot w-3 h-3 rounded-full bg-slate-400 dark:bg-slate-600 hover:bg-blue-500 hover:cursor-pointer transition-all duration-200"
    data-section="5"
    data-target="footer"
    aria-label="Ir a contacto"
  ></button>
</nav>

<script>
  const sections = ['hero', 'problema', 'comparacion', 'solucion', 'precios', 'footer'];
  const dots = document.querySelectorAll('.nav-dot');
  
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const target = dot.getAttribute('data-target');
      const el = document.getElementById(target || '');
      if (el) {
        el.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
  
  function updateDots() {
    const scrollPos = window.scrollY + window.innerHeight / 2;
    
    let currentSection = 0;
    for (let i = 0; i < sections.length; i++) {
      const section = document.getElementById(sections[i]);
      if (section) {
        const sectionTop = section.offsetTop;
        const sectionHeight = section.offsetHeight;
        if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
          currentSection = i;
          break;
        }
      }
    }
    
    dots.forEach((dot, index) => {
      const dotEl = dot as HTMLElement;
      dotEl.classList.remove('bg-blue-600', 'w-4', 'h-4', 'animate-pulse', 'bg-green-500');
      dotEl.classList.add('bg-slate-400', 'dark:bg-slate-600', 'w-3', 'h-3');
      
      if (index === currentSection) {
        dotEl.classList.remove('bg-slate-400', 'dark:bg-slate-600', 'w-3', 'h-3');
        dotEl.classList.add('bg-blue-600', 'w-4', 'h-4', 'animate-pulse');
      }
      
      // Special case: when on pricing (index 4), point 5 (footer) should pulse green
      if (currentSection === 4 && index === 5) {
        dotEl.classList.remove('bg-slate-400', 'dark:bg-slate-600', 'w-3', 'h-3', 'bg-blue-600');
        dotEl.classList.add('bg-green-500', 'w-4', 'h-4', 'animate-pulse');
      }
    });
  }
  
  window.addEventListener('scroll', updateDots);
  window.addEventListener('load', updateDots);
</script>
